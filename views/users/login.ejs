<% layout('layouts/boilerplate.ejs')%>


  <div class="login-body">

    <h1 class="display-6 mb-3 pb-3 text-center mt-5">Log in</h1>
    <form class="col-lg-6 offset-lg-3 col-md-8 offset-md-2" action="/login" method="POST" autocomplete="off" id="login-form">

      <div class="form-floating mb-3">
        <input type="text" name="username" id="username" class="form-control" placeholder="username" required />
        <label class="form-label" for="username">Username:</label>
        <span class="error-message" id="usernameError"></span>
      </div>

      <div class="form-floating mb-3">
        <input type="password" id="password" name="password" class="form-control" placeholder="password" required />
        <label class="form-label" for="password">Password:</label>
        <span class="error-message" id="passwordError"></span>
      </div>

      <div class="pt-1 mb-4 mt-4">
        <button class="login-btn btn btn-primary" type="submit">Login</button>
      </div>

      <!-- <p class="small mb-5 pb-lg-2"><a class="text-muted" href="#!">Forgot password?</a></p> -->
      <p>Don't have an account? <a href="/register" class="link-dark">Register here</a></p>

    </form>

  </div>