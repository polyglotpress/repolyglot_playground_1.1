  <% layout('layouts/boilerplate.ejs')%>

    <h1 class="mt-4 mb-4 text-center">Edit Profile</h1>

    <form action="/<%= user._id %>?_method=PUT" method="POST">

        <div class="mb-3">
            <label for="firstname" class="form-label">First Name:</label>
            <input type="text" id="firstname" class="form-control" name="user[firstname]" value="<%=user.firstname || '' %>">
        </div>
         <div class="mb-3">
            <label for="lastname" class="form-label">Last Name:</label>
            <input type="text" id="lastname" class="form-control" name="user[lastname]" value="<%=user.lastname || '' %>">
        </div>
         <div class="mb-3">
            <label for="nativeLanguage" class="form-label">Native Language</label>
            <input type="text" id="nativeLanguage" class="form-control" name="user[nativeLanguage]" value="<%=user.nativeLanguage || '' %>">
        </div>

        <div class="mb-3">
            <label for="username" class="form-label">Username:</label>
            <input type="text" id="username" class="form-control" name="user[username]" value="<%= user.username %>" required>
        </div>

    
        <button class="btn btn-primary">Update Profile</button>
        </form>
