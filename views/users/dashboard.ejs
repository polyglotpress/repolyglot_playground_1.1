<link rel="stylesheet" href="/css/styleDashboard.css" />
<% layout('layouts/boilerplate.ejs')%>

    <div class="container">
        <div class="main-body">

            <div class="row mt-5">
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex flex-column align-items-center text-center">
                                <!-- <img src="" alt="profile pic" class="rounded-circle" width="150"> -->
                                <div class="mt-3">
                                    <h4>
                                        <%=user.username%>
                                    </h4>
                                    <p class="text-secondary mb-3">Aspiring Polyglot</p>
                                    <!-- <p class="text-muted font-size-sm">bla bloa bla</p> -->
                                    <% if(currentUser && !user.equals(currentUser._id)) { %>
                                        <button class="btn btn-primary">Follow</button>
                                        <button class="btn btn-outline-primary">Message</button>

                                        <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-sm-3">
                                    <h6 class="mb-0">Full Name</h6>
                                </div>
                                <div class="col-sm-9 text-secondary">
                                    <%= user.firstname %>
                                        <%= user.lastname %>
                                </div>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-sm-3">
                                    <h6 class="mb-0">Email</h6>
                                </div>
                                <div class="col-sm-9 text-secondary">
                                    <%= user.email %>
                                </div>
                            </div>
                            <hr>


                            <div class="row">
                                <div class="col-sm-3">
                                    <h6 class="mb-0">Native Language</h6>
                                </div>
                                <div class="col-sm-9 text-secondary">
                                    <%= user.nativeLanguage %>
                                </div>
                            </div>
                            

                            <% if(currentUser && user._id.equals(currentUser._id)) { %>
                                <hr>
                                <div class="row">
                                    <div class="col-sm-12">
                                        <a class="btn btn-warning" href="/<%= user._id %>/edit">Edit</a>
                                        <button class="btn btn-danger" id="delete-profile" data-bs-toggle="modal"
                                            data-bs-target="#myModal">Delete</button>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-6" id="verify-delete-box">
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                        </div>
                    </div>
                </div>
            </div>


            <!--  -->

            <div class="row mt-32">

                <div class="col-md-6">
                    <div class="card mb-2 h-100">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-sm-3">
                                    <h6 class="mb-0">Languages aquiring:</h6>
                                </div>
                                <div class="col-sm-9 text-secondary">

                                    <% for(let language of user.languagesLearning) { %>
                                        <p>
                                            <%= language %>
                                        </p>
                                        <% } %>
                                </div>

                                  <% if(currentUser && user._id.equals(currentUser._id)) { %>
                                <div class="col-sm-12">
                                    <a class="btn btn-primary" href="/<%= user._id %>/languages/new">Add Language</a>
                                    <!-- <a class="btn btn-warning" id="edit-languages">Edit Languages</a> -->
                                </div>

                                   <% } %>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-sm-3">
                                    <h6 class="mb-0">Tasks</h6>
                                </div>
                                <div class="col-sm-9 text-secondary">

                                    <% for(let task of user.tasks) { %>

                                        <p>
                                            <%= task.title %>
                                        </p>
                                        <p>
                                            <%= task.language %>
                                        </p>
                                        <% } %>

                                            <p>
                                                total tasks: <%= user.tasks.length %>
                                            </p>
                                            <!-- <%= user.tasks %> -->
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-3 h-100">
                        <div class="card-body">
                            <div class="row">
                                <div class="text-center">
                                    <h6 class="mb-0">Words list</h6>
                                </div>
                                <div class="col-sm-9 text-secondary">


                                </div>

                                 <% if(currentUser && user._id.equals(currentUser._id)) { %>
                                <div class="col-sm-12">

                                    <a class="btn btn-primary" href="#"> + </a>
                                    <!-- <a class="btn btn-primary" href="#">Add Word</a>
                                  <a class="btn btn-primary" href="#">My list 1</a>
                                  <a class="btn btn-primary" href="#">My list 2</a> -->

                                </div>
                                <% } %>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-sm-3">
                                    <h6 class="mb-0">Stats</h6>
                                </div>
                                <div class="col-sm-9 text-secondary">


                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal -->
            <div class="modal fade" id="myModal">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h4 class="modal-title">Just a second, <%= user.username %>!</h4>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure you want to permanently delete your profile?
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Back</button>
                            <form id="delete-user-form" action="/<%= user._id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>