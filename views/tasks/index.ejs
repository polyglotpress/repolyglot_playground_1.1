<% layout('layouts/boilerplate.ejs')%>
    <link rel="stylesheet" href="/css/style1.css" />


    <!-- <div class="row mt-5">
        <div class="col text-end">
            <h4 class="d-inline">All tasks</h4>
        </div>
        <div class="col"> <a href="/tasks/new" class="btn btn-primary create-new ">Create new task</a></div>
    </div> -->

    <div class="title-container mt-3">

        <h1 class="display-6">All tasks</h1>

        <a href="/tasks/new" class="btn btn-primary create-new ">Create New</a>
    </div>

    <div class="cont mt-5">
        <div class="container">

            <% let count=4; %>

                <% for (let task of tasks) { %>

                    <% if(count==4) {%>

                        <div class="row mb-3">
                            <% count=0; %>
                                <% } %>
                                    <div class="col-3">

                                        <div class="card border-dark h-100">
                                            <div class="card-header text-lowercase">
                                                in: <%= task.category || 'other' %>
                                            </div>
                                            <div class="card-body">
                                                <p class="card-title"><strong>
                                                        <!-- <a class="text-center text-decoration-none" -->
                                                        <!-- href="/tasks/<%= task._id%>"> -->
                                                        <%= task.title %>
                                                            <!-- </a> -->
                                                    </strong>
                                                </p>
                                                <p class="card-subtitle mb-2 text-muted"> by <%=
                                                        task.creator.username %>
                                                </p>

                                            </div>
                                            <div class="card-footer">
                                                <a href="/tasks/<%= task._id%>"
                                                    class="card-link btn btn-info mt-auto">View</a>

                                                <!-- if you are the owner than edit -->
                                                <% if(currentUser && task.creator.id == currentUser._id) { %>
                                                    <a href="/tasks/<%= task._id %>/edit" class="card-link btn btn-info mt-auto">Edit</a>
                                                    <% } %>
                                            </div>
                                        </div>

                                    </div>

                                    <% if(count==3) {%>
                        </div>

                        <% } %>
                            <% count ++; %>
                                <% } %>

        </div>
    </div>